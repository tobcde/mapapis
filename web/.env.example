# Copia este archivo a .env.local y completá los valores reales.
# .env.local está gitignored — nunca lo commitees.

# Supabase — anon key (público por diseño, RLS protege la data)
VITE_SUPABASE_URL=https://adpbjslkswtnqklzejuy.supabase.co
VITE_SUPABASE_ANON_KEY=

# Mercado Pago — solo public key. El access token vive en Edge Functions.
VITE_MP_PUBLIC_KEY=

# Entorno: dev | prod (afecta logging y sample rates de Sentry)
VITE_ENV=dev

# Sentry DSN (opcional). Vacío = no se reportan errores.
VITE_SENTRY_DSN=

# Base path del bundle. Default '/mapapis-next/' para GitHub Pages subpath.
# Para preview local podés cambiar a '/' temporalmente.
VITE_BASE_PATH=/mapapis-next/
